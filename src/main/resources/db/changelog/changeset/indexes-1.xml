<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- books -->
    <changeSet author="Andrew Sinenko" id="idx-110">
        <createIndex  schemaName="things" tableName="books" indexName="idx_books_id">
            <column name="id"/>
        </createIndex>
        <createIndex  schemaName="things" tableName="books_authors" indexName="idx_books_authors_book_id">
            <column name="book_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>