<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xmlns:pro="http://www.liquibase.org/xml/ns/pro"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
        http://www.liquibase.org/xml/ns/pro
        http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd">

    <changeSet author="Andrew Sinenko" id="009">
        <createTable catalogName="things"
                     schemaName="things"
                     tableName="things_users">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_things_users"/>
            </column>
            <column name="user_name" type="varchar2(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_things_users_name"/>
            </column>
            <column name="password" type="varchar2(255)"/>
            <column name="email" type="varchar2(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_things_users_email"/>
            </column>
            <column name="first_name" type="varchar2(255)"/>
            <column name="last_name" type="varchar2(255)"/>
            <column name="phone_number" type="varchar2(255)"/>
            <column name="is_account_non_expired" type="boolean"/>
            <column name="is_account_non_locked" type="boolean"/>
            <column name="is_credentials_non_expired" type="boolean"/>
            <column name="is_enabled" type="boolean"/>
            <column name="create_date" type="timestamp"/>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="010">
        <createTable tableName="authorities" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_authorities"/>
            </column>
            <column name="name" type="varchar2(255)"/>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="011">
        <createTable tableName="user_roles" catalogName="things" schemaName="things">
            <column name="user_id" type="bigint">
                <constraints nullable="false" foreignKeyName="pk_user_role"/>
            </column>
            <column name="role_id" type="bigint">
                <constraints nullable="false" foreignKeyName="pk_role_user"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="012">
        <createTable tableName="things_tokens" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tokens"/>
            </column>
            <column name="token" type="varchar2(512)"/>
            <column name="revoked" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="expired" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="things_user" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_things_users_tokens"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="013">
        <createTable tableName="places" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_places"/>
            </column>
            <column name="name" type="varchar2(512)"/>
            <column name="parent_id" type="bigint"/>
            <column name="description" type="varchar2(512)"/>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="014">
        <createTable tableName="authors" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_authors"/>
            </column>
            <column name="name" type="varchar2(512)"/>
            <column name="note" type="varchar2(512)"/>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="015">
        <createTable tableName="genre" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_genre"/>
            </column>
            <column name="name" type="varchar2(512)"/>
            <column name="note" type="varchar2(512)"/>
        </createTable>
    </changeSet>
    <changeSet author="Andrew Sinenko" id="016">
        <createTable tableName="series" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_series"/>
            </column>
            <column name="name" type="varchar2(512)"/>
            <column name="note" type="varchar2(512)"/>
        </createTable>
    </changeSet>

    <changeSet author="Andrew Sinenko" id="017">
        <createTable tableName="books" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_books"/>
            </column>
            <column name="title" type="varchar(255)"/>
            <column name="publisher" type="varchar2(512)"/>
            <column name="year" type="date"/>
            <column name="volume_number" type="varchar2(512)"/>
            <column name="genre_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_genre_type"/>
            </column>
            <column name="series_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_series_type"/>
            </column>
            <column name="description" type="varchar2(512)"/>
        </createTable>
    </changeSet>

    <changeSet author="Andrew Sinenko" id="018">
        <createTable tableName="vendors" schemaName="things" catalogName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_vendors"/>
            </column>
            <column name="name" type="varchar2(512)"/>
        </createTable>
    </changeSet>

    <changeSet author="Andrew Sinenko" id="019">
        <createTable tableName="tools" catalogName="things"
                     schemaName="things">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tools"/>
            </column>
            <column name="tool_type" type="varchar2(512)"/>
            <column name="vendor" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_vendor_type"/>
            </column>
            <column name="date_of_purchasing" type="date"/>
            <column name="name" type="varchar2(512)"/>
            <column name="serial_number" type="varchar2(512)"/>
            <column name="description" type="varchar2(512)"/>
        </createTable>
    </changeSet>

    <changeSet author="Andrew Sinenko" id="020">
        <createTable tableName="books_authors" catalogName="things"
                     schemaName="things">
            <column name="book_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_books_authors1_type"/>
            </column>
            <column name="author_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_books_authors2_type" />
            </column>
            <column name="description" type="varchar2(512)"/>
        </createTable>
    </changeSet>


</databaseChangeLog>